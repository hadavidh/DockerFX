name: Deploy Production

on:
  workflow_dispatch:
    inputs:
      version:
        description: "Version à déployer (ex: v1.2.1)"
        required: true
        type: string

  workflow_run:
    workflows:
      - "Build Production"
    types:
      - completed

concurrency:
  group: production-deploy-${{ github.event.workflow_run.id || github.run_id }}
  cancel-in-progress: false

permissions:
  contents: read

jobs:
  deploy-production:
    name: 🚀 Deploy to Production Swarm
    runs-on: ubuntu-latest
    environment: production
    if: >
      github.event_name == 'workflow_dispatch' ||
      github.event.workflow_run.conclusion == 'success'

    steps:
      - name: Resolve production version
        id: meta
        run: |
          if [ "${{ github.event_name }}" = "workflow_dispatch" ]; then
            VERSION="${{ github.event.inputs.version }}"
            echo "version=$VERSION" >> "$GITHUB_OUTPUT"
            echo "version_from_workflow_run=false" >> "$GITHUB_OUTPUT"
          else
            echo "version_from_workflow_run=true" >> "$GITHUB_OUTPUT"
          fi

      - name: Checkout repository for tag resolution
        if: ${{ steps.meta.outputs.version_from_workflow_run == 'true' }}
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event.workflow_run.head_sha }}
          fetch-depth: 0

      - name: Extract version tag
        if: ${{ steps.meta.outputs.version_from_workflow_run == 'true' }}
        id: tag
        run: |
          VERSION="$(git tag --points-at HEAD | grep '^v[0-9]' | head -n1)"
          test -n "$VERSION" || (echo "Impossible de déterminer le tag de version sur ce commit" && exit 1)
          echo "version=$VERSION" >> "$GITHUB_OUTPUT"

      - name: Finalize image names
        id: images
        run: |
          VERSION="${{ steps.meta.outputs.version || steps.tag.outputs.version }}"
          test -n "$VERSION" || (echo "Version manquante" && exit 1)

          echo "version=$VERSION" >> "$GITHUB_OUTPUT"
          echo "backend_image=${{ secrets.DOCKERHUB_USERNAME }}/ict-trading-backend:$VERSION" >> "$GITHUB_OUTPUT"
          echo "frontend_image=${{ secrets.DOCKERHUB_USERNAME }}/ict-trading-frontend:$VERSION" >> "$GITHUB_OUTPUT"

      - name: Setup SSH
        run: |
          mkdir -p ~/.ssh
          echo "${{ secrets.VPS_SSH_KEY }}" > ~/.ssh/id_ed25519
          chmod 600 ~/.ssh/id_ed25519
          ssh-keyscan -H "${{ secrets.VPS_HOST }}" >> ~/.ssh/known_hosts

      - name: Deploy rolling update on Swarm
        run: |
          ssh \
            -o ServerAliveInterval=30 \
            -o ServerAliveCountMax=10 \
            -o TCPKeepAlive=yes \
            -o ConnectTimeout=10 \
            "${{ secrets.VPS_USER }}@${{ secrets.VPS_HOST }}" << 'EOF'
              set -e

              echo "${{ secrets.DOCKERHUB_TOKEN }}" | docker login -u "${{ secrets.DOCKERHUB_USERNAME }}" --password-stdin

              BACKEND_IMAGE="${{ steps.images.outputs.backend_image }}"
              FRONTEND_IMAGE="${{ steps.images.outputs.frontend_image }}"

              echo "Deploy backend image: $BACKEND_IMAGE"
              echo "Deploy frontend image: $FRONTEND_IMAGE"

              docker service update \
                --image "$BACKEND_IMAGE" \
                --update-parallelism 1 \
                --update-delay 10s \
                --with-registry-auth \
                ict-prod_backend

              docker service update \
                --image "$FRONTEND_IMAGE" \
                --update-parallelism 1 \
                --update-delay 10s \
                --with-registry-auth \
                ict-prod_frontend

              echo "Waiting for services to converge..."
              sleep 15

              docker service ls
              docker service ps ict-prod_backend --no-trunc
              docker service ps ict-prod_frontend --no-trunc

              echo "Checking public frontend on port 80..."
              for i in $(seq 1 12); do
                HTTP_CODE=$(curl -4 -s -o /dev/null -w "%{http_code}" \
                  --connect-timeout 3 \
                  --max-time 5 \
                  http://127.0.0.1/ || true)

                if [ "$HTTP_CODE" = "200" ] || [ "$HTTP_CODE" = "304" ]; then
                  echo "✅ Production frontend reachable (HTTP $HTTP_CODE)"
                  exit 0
                fi

                echo "Attempt $i/12... HTTP=$HTTP_CODE"
                sleep 5
              done

              echo "❌ Production frontend healthcheck failed"
              echo "Listening ports:"
              ss -ltnp | grep ':80' || true
              echo "Service status:"
              docker service ls
              docker service ps ict-prod_backend --no-trunc
              docker service ps ict-prod_frontend --no-trunc
              exit 1
            EOF

      - name: Show service status
        run: |
          ssh \
            -o ServerAliveInterval=30 \
            -o ServerAliveCountMax=10 \
            -o TCPKeepAlive=yes \
            -o ConnectTimeout=10 \
            "${{ secrets.VPS_USER }}@${{ secrets.VPS_HOST }}" \
            'docker service ls && docker service ps ict-prod_backend --no-trunc && docker service ps ict-prod_frontend --no-trunc'